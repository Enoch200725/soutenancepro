{% extends 'base.html.twig' %}

{% block body %}
<div class="app-shell">
    {% include '_partials/sidebar_admin.html.twig' %}

    <div class="main-content">
        <div class="page-header">
            <div class="page-eyebrow">Administration</div>
            <h1>Gestion des Soutenances</h1>
        </div>

        <div class="toolbar">
            <form method="GET" action="{{ path('app_administrateur_soutenance_index') }}" class="search-bar">
                <input type="date" name="date" value="{{ app.request.query.get('date') }}">
                <button type="submit" class="btn btn-outline btn-sm">Rechercher</button>
            </form>
            <a href="{{ path('app_administrateur_soutenance_new') }}" class="btn btn-accent">Programmer une soutenance</a>
        </div>

        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Etudiant</th>
                        <th>President</th>
                        <th>Rapporteur</th>
                        <th>Examinateur</th>
                        <th>Salle</th>
                        <th>Date</th>
                        <th>Heure</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for soutenance in soutenances %}
                    <tr>
                        <td>
                            <span class="name-with-seal">
                                <span class="seal-badge">{{ soutenance.etudiant.nom|first }}{{ soutenance.etudiant.prenom|first }}</span>
                                {{ soutenance.etudiant.nom }} {{ soutenance.etudiant.prenom }}
                            </span>
                        </td>
                        <td class="cell-muted">{{ soutenance.president.nom }} {{ soutenance.president.prenom }}</td>
                        <td class="cell-muted">{{ soutenance.rapporteur.nom }} {{ soutenance.rapporteur.prenom }}</td>
                        <td class="cell-muted">{{ soutenance.examinateur.nom }} {{ soutenance.examinateur.prenom }}</td>
                        <td class="cell-mono">{{ soutenance.salle.code }}</td>
                        <td>{{ soutenance.date ? soutenance.date|date('d/m/Y') : '' }}</td>
                        <td class="cell-mono">{{ soutenance.heure ? soutenance.heure|date('H:i') : '' }}</td>
                        <td>
                            <a href="{{ path('app_administrateur_soutenance_edit', {id: soutenance.id}) }}" class="btn btn-outline btn-sm">Modifier</a>
                            <form method="POST" action="{{ path('app_administrateur_soutenance_delete', {id: soutenance.id}) }}" style="display:inline" onsubmit="return confirm('Annuler cette soutenance ?');">
                                <button type="submit" class="btn btn-danger btn-sm">Annuler</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="empty-row">Aucune soutenance programmee.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}