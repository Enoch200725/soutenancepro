{% extends 'base.html.twig' %}

{% block body %}
<div class="app-shell">
    {% include '_partials/sidebar_admin.html.twig' %}

    <div class="main-content">
        <div class="page-header">
            <div class="page-eyebrow">Administration</div>
            <h1>Programmer une soutenance</h1>
        </div>

        {% if app.session.flashBag.has('errors') %}
            <div class="alert alert-error">
                {% for msg in app.session.flashBag.get('errors') %}
                    <p>{{ msg }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <div class="card" style="max-width: 600px;">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('app_administrateur_soutenance_index') }}" class="btn btn-outline">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}