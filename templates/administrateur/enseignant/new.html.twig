{% extends 'base.html.twig' %}

{% block body %}
<div class="app-shell">
    {% include '_partials/sidebar_admin.html.twig' %}

    <div class="main-content">
        <div class="page-header">
            <div class="page-eyebrow">Administration</div>
            <h1>Ajouter un enseignant</h1>
        </div>

        <div class="card" style="max-width: 560px;">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('app_administrateur_enseignant_index') }}" class="btn btn-outline">Annuler</a>
                </div>
            {{ form_end(form) }}
            <p style="margin-top: 16px; font-size: 13px;"><em>Mot de passe par defaut attribue : enseignant123</em></p>
        </div>
    </div>
</div>
{% endblock %}